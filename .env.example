# Local template — copy to `.env.local` (gitignored). For Vercel production, see docs/VERCEL-SETUP.md
# Local example (Docker: npm run db:up — see docs/LOCAL-DATABASE.md)
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/woxbin
DATABASE_URL=
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: send HSTS header (only with HTTPS). Vercel sets VERCEL=1 automatically.
# WOX_ENABLE_HSTS=1
# Optional: strict Content-Security-Policy baseline (test all flows after enabling). See docs/SECURITY.md
# WOX_ENFORCE_CSP=1
# Match how you open the app (localhost vs LAN IP). Used by NextAuth + inlined for the client bundle via next.config.mjs.
NEXTAUTH_URL=http://localhost:3000
# NextAuth: use the request Host for redirects (required for LAN / alternate hostnames unless NEXTAUTH_URL matches).
# In development, next.config.mjs defaults this to true when unset. For self-hosted production (not Vercel), set explicitly:
# AUTH_TRUST_HOST=true
# Tools surface switch. Leave unset or 0 while the tools product is unfinished; set to 1 to expose /tools and /api/convert.
# WOX_ENABLE_TOOLS=0

# Optional paid tiers: public HTTPS checkout / portal URLs (PayMongo, Xendit, Paddle, etc.).
# Used by /pricing and /settings/billing. Leave empty until configured. See docs/BILLING.md and docs/PAYMONGO.md.
# NEXT_PUBLIC_PRO_UPGRADE_URL=https://pay.paymongo.com/...
# NEXT_PUBLIC_TEAM_UPGRADE_URL=https://pay.paymongo.com/...
# NEXT_PUBLIC_BILLING_PORTAL_URL=https://your-billing-help-or-portal-page
NEXT_PUBLIC_PRO_UPGRADE_URL=
NEXT_PUBLIC_TEAM_UPGRADE_URL=
NEXT_PUBLIC_BILLING_PORTAL_URL=
# Internal support is built into /support and /support/manage. No support env is required.

# Optional: Stripe-only webhook automation — sync plan to database. See docs/BILLING-WEBHOOKS.md
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO_ID=price_...
# STRIPE_PRICE_TEAM_ID=price_...
# Or comma-separated: STRIPE_PRICE_PRO_IDS=price_a,price_b
# Cloudflare Turnstile — bot protection for /sign-up and anonymous publish. Free tier: dash.cloudflare.com → Turnstile.
# Add localhost (and your prod domain) to the widget’s hostnames. See docs/TURNSTILE.md
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: rolling session idle timeout in minutes (JWT refresh / browser session revoke). Default 30.
# SESSION_IDLE_MINUTES=30

# Optional SMTP (transactional / admin test). See docs/SMTP.md
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM="Wox-Bin <noreply@example.com>"

# Hosted quotas for moderators/admins: override staff limits (free | pro | team | admin). If unset, staff use
# the built-in "admin" plan tier (very high limits). See docs/ADMIN.md.
# ADMIN_QUOTA_PLAN=pro

# Pastebin → WOX-Bin migration (POST /api/migrate/pastebin). Get a dev key from your Pastebin account API page.
# PASTEBIN_API_DEV_KEY=

# Optional: max bytes for POST /api/convert/image (sharp). Default ~12 MB, capped at 25 MB.
# CONVERT_IMAGE_MAX_BYTES=12582912

# FFmpeg worker + S3-compatible storage (MinIO, R2, AWS S3). See docs/CONVERSION-WORKER.md
# CONVERT_S3_BUCKET=woxbin-convert
# CONVERT_S3_ACCESS_KEY=
# CONVERT_S3_SECRET_KEY=
# CONVERT_S3_REGION=us-east-1
# Local MinIO from docker-compose: CONVERT_S3_ENDPOINT=http://127.0.0.1:9000
# CONVERT_S3_ENDPOINT=
# CONVERT_S3_FORCE_PATH_STYLE=true
# CONVERT_JOB_MAX_INPUT_BYTES=524288000
# CONVERT_PRESIGN_TTL_SECONDS=900
# CONVERT_WORKER_POLL_MS=3000
# presign = browser uploads directly to S3 (default when VERCEL=1 at build). proxy = multipart via Next (local MinIO without CORS).
# CONVERT_UPLOAD_VIA=presign
# Alias keys also supported: CONVERT_S3_ACCESS_KEY_ID, CONVERT_S3_SECRET_ACCESS_KEY (see lib/convert/convert-s3-env.ts)

# Optional: headless Chromium export (see docs/CODE_IMAGE_SERVER.md). Requires: npx playwright install chromium
# CODE_IMAGE_PLAYWRIGHT_EXPORT=1
# NEXT_PUBLIC_CODE_IMAGE_PLAYWRIGHT_EXPORT=1
