{
  "name": "wox-bin-next",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,css}\"",
    "typecheck": "next typegen && tsc --noEmit --incremental false",
    "clean:next": "node scripts/rm-next.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "discord:bot": "tsx scripts/discord-bot.ts",
    "discord:invite": "tsx scripts/discord-invite.ts",
    "make:admin": "tsx scripts/make-admin.ts",
    "migrate:legacy": "tsx scripts/migrate-legacy.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "extension:build": "npm run build --prefix bookmarkfs",
    "postinstall": "node scripts/copy-pdf-worker.mjs",
    "gen:example-big-paste": "node scripts/generate-example-big-paste.mjs",
    "gen:convertio-formats": "node scripts/generate-convertio-formats-ts.mjs",
